{
  "name": "stelgano",
  "version": "2.0.0-dev",
  "description": "Anonymous messaging via contact-layer steganography. v2 — Cloudflare Workers + Assets + Durable Objects + D1.",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "types": "wrangler types",
    "postinstall": "wrangler types",
    "precommit": "npm run typecheck && npm run check && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:html": "node scripts/build-html.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:csp_hashes": "node scripts/build-csp-hashes.mjs",
    "build:client": "esbuild src/client/chat.ts --bundle --minify --format=esm --target=es2022 --outfile=public/assets/chat.js",
    "build:pbkdf2_worker": "esbuild src/client/workers/pbkdf2.ts --bundle --minify --format=iife --target=es2022 --outfile=public/assets/pbkdf2_worker.js",
    "build:config_patch": "esbuild src/client/config-patch.ts --bundle --minify --format=esm --target=es2022 --outfile=public/assets/config-patch.js",
    "build:css": "tailwindcss -i src/client/app.css -o public/assets/app.css --minify",
    "build": "npm run build:html && npm run build:icons && npm run build:csp_hashes && npm run build:client && npm run build:pbkdf2_worker && npm run build:config_patch && npm run build:css",
    "d1:migrate:local": "wrangler d1 migrations apply stelgano --local",
    "d1:migrate:remote": "wrangler d1 migrations apply stelgano --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/vitest-pool-workers": "^0.5.36",
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "lucide-static": "^1.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.42",
    "phone-number-generator-js": "^1.4.0"
  }
}
