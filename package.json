{
  "name": "stelgano",
  "version": "2.0.0-dev",
  "description": "Anonymous messaging via contact-layer steganography. v2 — Cloudflare Pages + Durable Objects + D1.",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev",
    "deploy": "wrangler pages deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:client": "esbuild src/client/chat.ts --bundle --minify --format=esm --target=es2022 --outfile=public/assets/chat.js",
    "build:css": "tailwindcss -i src/client/app.css -o public/assets/app.css --minify",
    "build": "npm run build:client && npm run build:css",
    "d1:migrate:local": "wrangler d1 migrations apply stelgano --local",
    "d1:migrate:remote": "wrangler d1 migrations apply stelgano --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.36",
    "@cloudflare/workers-types": "^4.20250414.0",
    "esbuild": "^0.24.2",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
