<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Favicons --%>
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    
    <%!-- OpenGraph & SEO --%>
    <meta property="og:title" content="sTELgano - Zero Trace Encrypted Channels" />
    <meta property="og:description" content="The messaging app hidden in your contacts. No accounts, no logs, end-to-end encrypted." />
    <meta property="og:image" content="https://stelgano.com/images/og_image.png" />
    <meta property="og:url" content="https://stelgano.com" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="sTELgano - Zero Trace Encrypted Channels" />
    <meta name="twitter:description" content="The messaging app hidden in your contacts. No accounts, no logs, end-to-end encrypted." />
    <meta name="twitter:image" content="https://stelgano.com/images/og_image.png" />

    <%!-- Minimal title — reveals nothing about the nature of the service in browser history --%>
    <.live_title default="sTELgano">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <%!-- Bootstrap cleanup. Carries the per-request CSP nonce because
         script-src no longer permits generic 'unsafe-inline' — see
         StelganoWeb.Plugs.CspNonce.

         1. Panic clear: if the URL carries ?p=1 (set by the /x PanicController
            redirect), wipe sessionStorage completely and strip the flag from
            the address bar / history.
         2. Service-worker + cache cleanup for any stragglers from older
            deployments that shipped a sw.js. --%>
    <script nonce={@csp_nonce}>
      try {
        var url = new URL(window.location.href);
        if (url.searchParams.get("p") === "1") {
          sessionStorage.clear();
          url.searchParams.delete("p");
          window.history.replaceState(null, "", url.pathname + url.search + url.hash);
        }
      } catch (e) {}

      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.getRegistrations().then(registrations => {
          for (let registration of registrations) { registration.unregister(); }
        });
        if ("caches" in window) {
          caches.keys().then(names => {
            for (let name of names) caches.delete(name);
          });
        }
      }
    </script>
  </head>
  <body class="antialiased">
    <div class="bg-grid-container">
      <div class="bg-grid"></div>
      <div class="bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
      </div>
      <div class="noise-overlay"></div>
    </div>
    {@inner_content}
  </body>
</html>
