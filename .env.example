# sTELgano — environment variables
#
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# All variables listed below are read by `config/runtime.exs`.
# Required-in-prod variables raise at boot if unset.
#
# Deployment note: on a production droplet, this file lives at
# `/opt/stelgano/.env` (mode 0600, owned by the deploy user). The
# systemd unit in deploy/stelgano.service sources it as
# EnvironmentFile, and the GH Actions deploy workflow sources it
# before running migrations. Keep it out of version control.

# ---------------------------------------------------------------------------
# Phoenix / release
# ---------------------------------------------------------------------------

# Enable the HTTP endpoint when running a `mix release`.
# REQUIRED in prod (the systemd unit runs `bin/stelgano start`, which
# only binds the endpoint when this is truthy). Leave unset in dev
# (mix phx.server starts it automatically).
PHX_SERVER=true

# Port the HTTP endpoint binds to. Default: 4000.
# PORT=4000

# Production hostname used for URL generation (routing, OAuth callbacks, etc).
# REQUIRED in prod.
PHX_HOST=stelgano.com

# Base secret for cookie signing / session encryption.
# Generate with: mix phx.gen.secret
# REQUIRED in prod.
SECRET_KEY_BASE=replace-me-with-`mix phx.gen.secret`-output

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# REQUIRED in prod.
# Format: ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=ecto://postgres:postgres@localhost/stelgano_prod

# Ecto connection pool size. Default: 10.
# POOL_SIZE=10

# Set to "true" or "1" to connect to the database over IPv6.
# ECTO_IPV6=false

# ---------------------------------------------------------------------------
# Clustering (optional)
# ---------------------------------------------------------------------------

# DNS query used by :dns_cluster for multi-node release deployments.
# Leave unset for single-node.
# DNS_CLUSTER_QUERY=stelgano.internal

# ---------------------------------------------------------------------------
# Admin dashboard (HTTP Basic Auth for /admin)
# ---------------------------------------------------------------------------

# Username for the admin dashboard. Default: "admin".
# ADMIN_USERNAME=admin

# Password for the admin dashboard. Use a strong, randomly generated value.
# REQUIRED in prod.
ADMIN_PASSWORD=replace-me-with-a-strong-password

# ---------------------------------------------------------------------------
# Monetization — paid tiers (optional; disabled by default)
# ---------------------------------------------------------------------------

# Flip to "true" to enable paid dedicated numbers. Everything below is only
# read when this is on.
# MONETIZATION_ENABLED=false

# Paystack API credentials. REQUIRED when MONETIZATION_ENABLED=true.
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Post-payment redirect URL. REQUIRED when MONETIZATION_ENABLED=true.
# PAYSTACK_CALLBACK_URL=https://stelgano.com/payment/callback

# Domain you control, used as the @domain of the anonymous placeholder
# email we send to Paystack on transaction initialize (Paystack requires
# an email and mails receipts to it). REQUIRED when MONETIZATION_ENABLED=true.
# MUST be a domain you own — if a third party owns it, every transaction
# receipt lands in their inbox. Typically set to your PHX_HOST value; no
# MX record is fine, since we want receipts to bounce/void.
# PAYSTACK_RECEIPT_EMAIL_DOMAIN=stelgano.com

# Free-tier room TTL in days. Default: 7.
# FREE_TTL_DAYS=7

# Paid-tier room TTL in days. Default: 365.
# PAID_TTL_DAYS=365

# Price in the smallest currency unit (e.g. cents for USD, kobo for NGN).
# Default: 200.
# PRICE_CENTS=200

# ISO 4217 currency code for billing. This is what the UI shows the user
# and what `PRICE_CENTS` is denominated in. Default: USD.
# PAYMENT_CURRENCY=USD

# ---------------------------------------------------------------------------
# Paystack settlement currency (optional)
# ---------------------------------------------------------------------------
# Paystack merchant accounts only accept specific currencies. If yours
# does not accept PAYMENT_CURRENCY (e.g. you want to show USD to users
# but your account only settles in KES), set this to the ISO 4217 code
# your account accepts.
#
# When set and different from PAYMENT_CURRENCY, `Paystack.initialize/3`
# converts PRICE_CENTS via the in-memory `FxRate` GenServer (fed by a
# free public CDN rate API, refreshed every 24h).
#
# Leave unset to disable conversion entirely.
# PAYSTACK_SETTLEMENT_CURRENCY=KES

# Percent added on top of the converted amount to absorb FX drift
# between the cached rate and the charge-settlement moment.
# Default: 5.
# PAYSTACK_FX_BUFFER_PCT=5

# Seed rate for `FxRate` so the first payment after a cold start works
# even if the rate API is unreachable. Interpreted as the `quote` per
# unit of `base` (e.g. 129.5 means 1 USD = 129.5 KES). Optional, but
# recommended when PAYSTACK_SETTLEMENT_CURRENCY is set.
# PAYMENT_FX_FALLBACK_RATE=129.5
