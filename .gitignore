# =============================================================================
# v1 — Phoenix/Elixir tree (kept under elixir/ on this branch as reference
# during the v2 migration; see docs/MIGRATION.md). All Mix-generated
# artefacts live under elixir/ now.
# =============================================================================

# Mix compiled artifacts (also catch any stale copies left at root from
# before the elixir/ move; pure build artefacts so anchoring is unnecessary)
/elixir/_build/
_build/

# `mix test --cover` output
/elixir/cover/
cover/

# Mix dependencies
/elixir/deps/
deps/

# ExDoc output
/elixir/doc/

# .fetch files (local dep edits)
/elixir/.fetch

# Phoenix asset pipeline artefacts
/elixir/priv/static/assets/
/elixir/priv/static/cache_manifest.json
/elixir/priv/static/**/*-????????????????????????????????.*
/elixir/priv/static/**/*.gz

# Dialyzer PLTs
/elixir/priv/plts/*.plt
/elixir/priv/plts/*.plt.hash

# ExCoveralls
/elixir/coveralls.json

# Phoenix-side npm
/elixir/assets/node_modules/

# =============================================================================
# v2 — Cloudflare Workers / Node / Wrangler / TypeScript
# =============================================================================

/node_modules/
/.wrangler/
/dist/
.dev.vars
.dev.vars.*

# Wrangler-generated runtime type definitions — regenerated via
# `wrangler types` whenever wrangler.toml changes. Should not be
# committed (per-machine, derived from config).
/worker-configuration.d.ts

# Build outputs in public/ — regenerated by `npm run build` from
# src/client/ and _worker.ts. public/fonts/ and public/images/ ARE
# tracked (they're source files copied once from elixir/priv/static/).
# Only the generated HTML, the bundled Pages worker, and the bundled
# assets/ are derived.
/public/*.html
/public/_worker.js
/public/_worker.js.map
/public/assets/

# =============================================================================
# Cross-cutting (apply regardless of v1/v2 location)
# =============================================================================

# BEAM crash dumps (could land at root if `mix` is run from root by mistake)
erl_crash.dump

# Mix archive artefacts
*.ez

# Temporary files
/tmp/

# Hex tarball
stelgano-*.tar

# npm
npm-debug.log
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.iml
.vscode/
*.swp
*.swo

# Secret env files
.env
.env.local

# Lost/scratch code
/lost_code/

# Private project files (not for public repo)
/project/launch_content*.md
/project/design-system.css
/project/feedback/
/project/TODOs.md
