# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
stelgano-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# `mix phx.digest` output — regenerated on every build.
# Matches files with the 32-hex-char digest suffix (e.g. foo-abc123…def.ext)
# and the gzipped companion files it emits for static compression.
/priv/static/**/*-????????????????????????????????.*
/priv/static/**/*.gz

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/


# Dialyzer PLTs (large, rebuilt per-environment)
/priv/plts/*.plt
/priv/plts/*.plt.hash

# Test coverage
/cover/

# ExCoveralls
coveralls.json

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.iml
.vscode/
*.swp
*.swo

# Secret env files
.env
.env.local

# Lost/scratch code (not part of the project)
/lost_code/

# Private project files (not for public repo)
/project/launch_content*.md
/project/design-system.css
/project/feedback/
/project/TODOs.md
